# Copy to .env and adjust. python-dotenv is optional; export vars in production instead.

PORT=5000

# Poll interval for watched symbols (seconds). Yahoo data is delayed; 20–30 is typical.
MARKET_REFRESH_SECONDS=25

# Cap symbols kept in the realtime rotation (avoid rate limits)
MAX_WATCHED_SYMBOLS=200

# Comma-separated origins for Lovable / Vite / your production domain
# ALLOWED_ORIGINS=https://your-app.lovable.app,http://localhost:5173

# Optional: require X-API-Key header on /api/* (recommended when exposed to the internet)
# STOCK_API_KEY=

# Optional: RSS feed for world_context headlines in /api/v1/intelligence/analyze
# WORLD_RSS_URL=https://example.com/news.xml

# Optional: disable background quote poller (worker-only or tests)
# DISABLE_MARKET_POLLER=1
